GEMINI_API_KEY=
# Optional admission controls. Defaults are conservative and every value is
# bounded again in code before reaching a database RPC.
# AI_SYNC_RATE_WINDOW_SECONDS=600
# AI_ANALYZE_DREAM_MAX_PER_WINDOW_FREE=6
# AI_ANALYZE_DREAM_MAX_PER_WINDOW_PLUS=20
# AI_ANALYZE_DREAM_GLOBAL_MAX_PER_WINDOW=300
# AI_CATEGORIZE_DREAM_MAX_PER_WINDOW_FREE=12
# AI_CHAT_MAX_PER_WINDOW_FREE=30
# AI_TRANSCRIBE_MAX_PER_WINDOW_FREE=10
# AI_ANALYSIS_MAX_ATTEMPTS=3
# AI_ANALYSIS_MAX_ACTIVE_FREE=1
# AI_ANALYSIS_MAX_ACTIVE_PLUS=2
# AI_ANALYSIS_MAX_PER_WINDOW_FREE=4
# AI_ANALYSIS_MAX_PER_WINDOW_PLUS=12
# AI_ANALYSIS_MAX_GLOBAL_ACTIVE=200
# AI_IMAGE_MAX_ATTEMPTS=3
# AI_IMAGE_MAX_ACTIVE_FREE=1
# AI_IMAGE_MAX_ACTIVE_PLUS=2
# AI_IMAGE_MAX_PER_WINDOW_FREE=4
# AI_IMAGE_MAX_PER_WINDOW_PLUS=12
# AI_IMAGE_MAX_GLOBAL_ACTIVE=200
# Optional image-model overrides. Stable defaults are used when omitted.
# IMAGEN_PLUS_MODEL=gemini-3.1-flash-image
# IMAGEN_FREE_MODEL=gemini-3.1-flash-lite-image
# IMAGEN_MODEL=gemini-3.1-flash-image # legacy subscriber-only alias

# RevenueCat (server-side, API v2)
# Prefer `REVENUECAT_SECRET_API_KEY`; the other keys are supported as legacy aliases.
REVENUECAT_SECRET_API_KEY=
# REVENUECAT_API_KEY=
# REVENUECAT_SECRET_KEY=
REVENUECAT_PROJECT_ID=

# RevenueCat webhook authentication (called by RevenueCat servers)
REVENUECAT_WEBHOOK_SECRET=

# RevenueCat reconcile authentication (internal/admin endpoint)
REVENUECAT_RECONCILE_SECRET=

# Usage:
#   npx supabase functions serve --env-file supabase/functions/.env
#   npx supabase secrets set --env-file supabase/functions/.env
