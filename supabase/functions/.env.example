GEMINI_API_KEY=
# Optional image-model overrides. Stable defaults are used when omitted.
# IMAGEN_PLUS_MODEL=gemini-3.1-flash-image
# IMAGEN_FREE_MODEL=gemini-3.1-flash-lite-image
# IMAGEN_MODEL=gemini-3.1-flash-image # legacy subscriber-only alias

# RevenueCat (server-side, API v2)
# Prefer `REVENUECAT_SECRET_API_KEY`; the other keys are supported as legacy aliases.
REVENUECAT_SECRET_API_KEY=
# REVENUECAT_API_KEY=
# REVENUECAT_SECRET_KEY=
REVENUECAT_PROJECT_ID=

# RevenueCat webhook authentication (called by RevenueCat servers)
REVENUECAT_WEBHOOK_SECRET=

# RevenueCat reconcile authentication (internal/admin endpoint)
REVENUECAT_RECONCILE_SECRET=

# Usage:
#   npx supabase functions serve --env-file supabase/functions/.env
#   npx supabase secrets set --env-file supabase/functions/.env
