{
  "version": 1,
  "name": "dreamer-db-contract",
  "description": "Minimal runtime contract required for mobile dream sync and quota enforcement to work against Supabase.",
  "requiredTables": [
    {
      "schema": "public",
      "name": "dreams",
      "requiredColumns": [
        "id",
        "user_id",
        "created_at",
        "updated_at",
        "client_updated_at",
        "revision_id",
        "transcript",
        "title",
        "interpretation",
        "shareable_quote",
        "image_url",
        "chat_history",
        "theme",
        "dream_type",
        "is_favorite",
        "is_analyzed",
        "analyzed_at",
        "analysis_status",
        "analysis_request_id",
        "exploration_started_at",
        "client_request_id",
        "has_person",
        "has_animal",
        "memory",
        "analysis_details"
      ]
    },
    {
      "schema": "public",
      "name": "ai_jobs",
      "requiredColumns": [
        "id",
        "user_id",
        "guest_fingerprint",
        "dream_id",
        "job_type",
        "status",
        "request_payload",
        "result_payload",
        "error_code",
        "error_message",
        "attempt_count",
        "max_attempts",
        "client_request_id",
        "quota_claimed",
        "quota_claimed_at",
        "created_at",
        "started_at",
        "finished_at"
      ]
    },
    {
      "schema": "public",
      "name": "quota_limits",
      "requiredColumns": [
        "tier",
        "period",
        "quota_type",
        "quota_limit",
        "updated_at"
      ]
    },
    {
      "schema": "public",
      "name": "quota_usage",
      "requiredColumns": [
        "id",
        "user_id",
        "dream_id",
        "quota_type",
        "occurred_at",
        "metadata"
      ]
    },
    {
      "schema": "public",
      "name": "guest_usage",
      "requiredColumns": [
        "id",
        "fingerprint_hash",
        "analysis_count",
        "exploration_count",
        "image_count",
        "is_upgraded",
        "upgraded_user_id",
        "upgraded_at",
        "first_seen_at",
        "last_seen_at"
      ]
    },
    {
      "schema": "public",
      "name": "guest_analysis_quota_claims",
      "requiredColumns": [
        "fingerprint_hash",
        "analysis_request_id",
        "claimed_at"
      ]
    },
    {
      "schema": "public",
      "name": "product_analytics_events",
      "requiredColumns": [
        "id",
        "event_id",
        "event_name",
        "schema_version",
        "occurred_at",
        "received_at",
        "journey_id",
        "platform",
        "app_version",
        "locale",
        "properties"
      ]
    },
    {
      "schema": "analytics_private",
      "name": "product_analytics_daily_aggregates",
      "requiredColumns": [
        "id",
        "event_date",
        "event_name",
        "platform",
        "locale",
        "app_version",
        "properties",
        "journey_count",
        "event_count",
        "refreshed_at"
      ]
    }
  ],
  "requiredFunctions": [
    {
      "schema": "public",
      "name": "get_guest_quota_status",
      "identityArguments": "p_fingerprint text",
      "result": "json"
    },
    {
      "schema": "public",
      "name": "increment_guest_quota",
      "identityArguments": "p_fingerprint text, p_quota_type text, p_limit integer",
      "result": "json"
    },
    {
      "schema": "public",
      "name": "claim_guest_analysis_quota",
      "identityArguments": "p_fingerprint text, p_analysis_request_id uuid, p_limit integer",
      "result": "jsonb"
    },
    {
      "schema": "public",
      "name": "release_guest_quota_claim",
      "identityArguments": "p_fingerprint text, p_quota_type text",
      "result": "json"
    },
    {
      "schema": "public",
      "name": "mark_fingerprint_upgraded",
      "identityArguments": "p_fingerprint text, p_user_id uuid",
      "result": "boolean"
    },
    {
      "schema": "public",
      "name": "set_exploration_started_at_from_chat_history",
      "identityArguments": "",
      "result": "trigger"
    },
    {
      "schema": "public",
      "name": "log_user_quota_event",
      "identityArguments": "",
      "result": "trigger"
    },
    {
      "schema": "public",
      "name": "enforce_authenticated_monthly_quota",
      "identityArguments": "",
      "result": "trigger"
    },
    {
      "schema": "public",
      "name": "enforce_quota_for_chat",
      "identityArguments": "",
      "result": "trigger"
    },
    {
      "schema": "analytics_private",
      "name": "refresh_product_analytics_daily_aggregates",
      "identityArguments": "",
      "result": "void"
    }
  ],
  "requiredTriggers": [
    {
      "schema": "public",
      "table": "dreams",
      "name": "trg_00_set_exploration_started_at_from_chat_history",
      "functionSchema": "public",
      "functionName": "set_exploration_started_at_from_chat_history",
      "definitionIncludes": [
        "BEFORE INSERT OR UPDATE",
        "EXECUTE FUNCTION public.set_exploration_started_at_from_chat_history()"
      ]
    },
    {
      "schema": "public",
      "table": "dreams",
      "name": "trg_10_enforce_authenticated_monthly_quota",
      "functionSchema": "public",
      "functionName": "enforce_authenticated_monthly_quota",
      "definitionIncludes": [
        "BEFORE INSERT OR UPDATE",
        "EXECUTE FUNCTION public.enforce_authenticated_monthly_quota()"
      ]
    },
    {
      "schema": "public",
      "table": "dreams",
      "name": "trg_log_quota_event_on_dreams",
      "functionSchema": "public",
      "functionName": "log_user_quota_event",
      "definitionIncludes": [
        "AFTER INSERT OR UPDATE",
        "EXECUTE FUNCTION public.log_user_quota_event()"
      ]
    },
    {
      "schema": "public",
      "table": "dreams",
      "name": "trg_enforce_quota_for_chat",
      "functionSchema": "public",
      "functionName": "enforce_quota_for_chat",
      "definitionIncludes": [
        "BEFORE UPDATE OF chat_history",
        "EXECUTE FUNCTION public.enforce_quota_for_chat()"
      ]
    }
  ],
  "requiredIndexes": [
    {
      "schema": "public",
      "table": "ai_jobs",
      "name": "idx_ai_jobs_type_actor_request",
      "unique": true,
      "definitionIncludes": [
        "coalesce((user_id)::text, guest_fingerprint)",
        "client_request_id"
      ]
    },
    {
      "schema": "public",
      "table": "ai_jobs",
      "name": "idx_ai_jobs_status_created_at",
      "unique": false,
      "columns": [
        "status",
        "created_at"
      ]
    },
    {
      "schema": "public",
      "table": "ai_jobs",
      "name": "idx_ai_jobs_actor_created_at",
      "unique": false,
      "definitionIncludes": [
        "coalesce((user_id)::text, guest_fingerprint)",
        "created_at DESC"
      ]
    },
    {
      "schema": "public",
      "table": "dreams",
      "name": "idx_dreams_user_client_request",
      "unique": true,
      "columns": [
        "user_id",
        "client_request_id"
      ]
    },
    {
      "schema": "public",
      "table": "quota_limits",
      "name": "quota_limits_pk",
      "unique": true,
      "columns": [
        "tier",
        "period",
        "quota_type"
      ]
    },
    {
      "schema": "public",
      "table": "quota_usage",
      "name": "idx_quota_usage_user_type_time",
      "unique": false,
      "columns": [
        "user_id",
        "quota_type",
        "occurred_at"
      ]
    },
    {
      "schema": "public",
      "table": "guest_usage",
      "name": "guest_usage_fingerprint_hash_key",
      "unique": true,
      "columns": [
        "fingerprint_hash"
      ]
    },
    {
      "schema": "public",
      "table": "guest_analysis_quota_claims",
      "name": "guest_analysis_quota_claims_pkey",
      "unique": true,
      "columns": [
        "fingerprint_hash",
        "analysis_request_id"
      ]
    },
    {
      "schema": "public",
      "table": "product_analytics_events",
      "name": "product_analytics_events_journey_occurred_idx",
      "unique": false,
      "columns": [
        "journey_id",
        "occurred_at"
      ]
    },
    {
      "schema": "analytics_private",
      "table": "product_analytics_daily_aggregates",
      "name": "product_analytics_daily_aggregates_date_event_idx",
      "unique": false,
      "columns": [
        "event_date",
        "event_name"
      ]
    }
  ],
