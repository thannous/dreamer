{
  "name": "noctalia",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "start": "expo start",
    "start:mock": "cp .env.mock .env.local && expo start",
    "start:real": "cp .env.real .env.local && expo start",
    "start:teststore": "cp .env.teststore .env.local && expo start",
    "start:supabase": "node ./scripts/start-supabase.js",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-android.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "npx expo export -p web && npx workbox-cli generateSW workbox-config.js",
    "generate-sitemap": "node ./scripts/generate-sitemap-v2.js",
    "content:build-manifest": "node ./scripts/build-content-manifest.js",
    "content:build-manifest:check": "node ./scripts/build-content-manifest.js --check",
    "content:audit-parity": "node ./scripts/audit-content-parity.js",
    "content:audit-parity:strict": "node ./scripts/audit-content-parity.js --strict-mobile",
    "validate-seo": "node ./scripts/validate-i18n-seo.js",
    "docs:check-links": "node ./scripts/check-docs-links.js",
    "docs:check-crosslinks": "node ./scripts/check-blog-crosslinking-plan.js",
    "serve:docs": "node ./scripts/serve-docs.js",
    "docs:update-reading-times": "node ./scripts/update-reading-times.js --write",
    "docs:enhance-articles-seo": "node ./scripts/enhance-blog-articles-seo.js",
    "docs:enhance-blog-index-seo": "node ./scripts/enhance-blog-index-seo.js",
    "docs:fix-eeat-signals": "node ./docs/scripts/fix-eeat-signals.js",
    "docs:fix-breadcrumb-jsonld": "node ./scripts/fix-breadcrumb-jsonld.js",
    "docs:fix-guides-architecture": "node ./scripts/fix-guides-architecture.js",
    "docs:cache-bust-assets": "node ./scripts/cache-bust-docs-assets.js",
    "docs:extract-blog-css": "node ./scripts/extract-blog-inline-css.js",
    "docs:generate-blog-image-variants": "node ./scripts/generate-blog-image-variants.js",
    "docs:add-blog-srcset": "node ./scripts/add-blog-srcset.js",
    "docs:add-blog-related-navigation": "node ./scripts/add-blog-related-navigation.js",
    "docs:audit-blog-i18n": "node ./scripts/audit-blog-i18n-parity.js",
    "fix-seo-urls": "node ./scripts/fix-seo-html-extensions.js",
    "docs:fix-fr-accents": "node ./scripts/restore-fr-accents.mjs --write",
    "ti-124:add-hub-pills": "node ./scripts/ti-124-add-hub-pills.js",
    "ti-97:add-sources-trust": "node ./scripts/ti-97-add-sources-trust.js",
    "ti-97:audit-assertive": "node ./scripts/ti-97-audit-assertive-phrases.js",
    "ti-97:eeat": "node ./scripts/ti-97-eeat-improvements.js",
    "ti-97:eeat:dry-run": "node ./scripts/ti-97-eeat-improvements.js --dry-run",
    "ti-97:eeat:verify": "node ./scripts/ti-97-eeat-improvements.js --verify-links",
    "lint": "expo lint app components hooks lib context constants services tests",
    "typecheck:app": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "jest",
    "test:e2e": "maestro test maestro/mock-existing-user.yml",
    "test:e2e:mock-quotas": "maestro test maestro/mock-existing-quotas.yml",
    "test:e2e:quotas": "maestro test maestro/guest-quota-flow.yml",
    "test:e2e:guest-limit": "maestro test maestro/guest-dream-limit-signup.yml",
    "build:apk": "echo 'Usage: npm run build:apk:mock | npm run build:apk:prod'",
    "build:apk:mock": "EXPO_PUBLIC_MOCK_MODE=true EAS_LOCAL_BUILD_ARTIFACTS_DIR=dist eas build -p android --profile preview --local",
    "build:apk:prod": "rm -f .env.local && EAS_LOCAL_BUILD_ARTIFACTS_DIR=dist eas build -p android --profile production-apk --local",
    "test:perf": "vitest run --config vitest.config.mts"
  },
